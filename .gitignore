# ---- Runtime data (never commit a database's contents) ----
# NOTE: keep these anchored to real runtime dirs. A bare `data/` or `**/data/`
# also matches the SOURCE route folder src/app/api/projects/[id]/data/, which
# silently dropped that route from git and broke the console on the server.
/data/
/api/data/
/engine/data/
*.wal
*.sst
web/naga-console/.data/

# ---- OS / editor ----
.DS_Store
*.log
.env
.env.local
